      "source": [
        "# Query 2: Employees with salary BETWEEN 70,000 AND 110,000\n",
        "# in Engineering OR Sales departments\n",
        "# Show all columns, sort by department then salary DESC\n",
        "\n",
        "query2 = '''\n",
        "    SELECT *\n",
        "    FROM   employees\n",
        "    WHERE  salary BETWEEN 70000 AND 110000\n",
        "      AND  department IN ('Engineering', 'Sales')\n",
        "    ORDER  BY department ASC, salary DESC\n",
        "'''\n",
        "\n",
        "df_query2 = pd.read_sql_query(query2, conn)\n",
        "print('Query 2 - Engineering / Sales employees with salary $70k-$110k')\n",
        "display(df_query2)"
      ]
    },
