      "source": [
        "# 3.1 Average performance_score by department using .groupby()\n",
        "avg_perf_by_dept = (\n",
        "    df.groupby('department')['performance_score']\n",
        "      .mean()\n",
        "      .round(2)\n",
        "      .reset_index()\n",
        "      .rename(columns={'performance_score': 'avg_performance_score'})\n",
        "      .sort_values('avg_performance_score', ascending=False)\n",
        ")\n",
        "\n",
        "print('3.1 - Average Performance Score by Department')\n",
        "display(avg_perf_by_dept)"
      ]
    },
