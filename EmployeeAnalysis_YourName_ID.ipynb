      "source": [
        "# Query 3: Count employees per department and calculate average salary\n",
        "# Sort by avg_salary DESC\n",
        "\n",
        "query3 = '''\n",
        "    SELECT   department,\n",
        "             COUNT(*)               AS employee_count,\n",
        "             ROUND(AVG(salary), 2)  AS avg_salary\n",
        "    FROM     employees\n",
        "    GROUP BY department\n",
        "    ORDER BY avg_salary DESC\n",
        "'''\n",
        "\n",
        "df_query3 = pd.read_sql_query(query3, conn)\n",
        "print('Query 3 - Employee count and average salary per department')\n",
        "display(df_query3)"
      ]
    },
