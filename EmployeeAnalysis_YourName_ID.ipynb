      "source": [
        "import sqlite3\n",
        "import random\n",
        "import pandas as pd\n",
        "\n",
        "# Seed for reproducibility\n",
        "random.seed(42)\n",
        "\n",
        "# Constants\n",
        "DEPARTMENTS = ['Engineering', 'Sales', 'Marketing', 'HR', 'Finance']\n",
        "NUM_RECORDS = 50  # at least 40 as required\n",
        "\n",
        "# Connect / create database\n",
        "conn = sqlite3.connect('employees.db')\n",
        "cursor = conn.cursor()\n",
        "\n",
        "# Create table\n",
        "cursor.execute('DROP TABLE IF EXISTS employees')\n",
        "cursor.execute('''\n",
        "    CREATE TABLE employees (\n",
        "        emp_id            INTEGER PRIMARY KEY,\n",
        "        name              TEXT    NOT NULL,\n",
        "        department        TEXT    NOT NULL,\n",
        "        salary            REAL    NOT NULL,\n",
        "        years_experience  INTEGER NOT NULL,\n",
        "        performance_score REAL    NOT NULL\n",
        "    )\n",
        "''')\n",
        "\n",
        "# Generate and insert 50 synthetic records\n",
        "records = []\n",
        "for i in range(1, NUM_RECORDS + 1):\n",
        "    record = (\n",
        "        i,\n",
        "        f'Employee_{i}',\n",
        "        random.choice(DEPARTMENTS),\n",
        "        round(random.uniform(50_000, 150_000), 2),\n",
        "        random.randint(1, 15),\n",
        "        round(random.uniform(1.0, 5.0), 1)\n",
        "    )\n",
        "    records.append(record)\n",
        "\n",
        "cursor.executemany(\n",
        "    'INSERT INTO employees VALUES (?, ?, ?, ?, ?, ?)',\n",
        "    records\n",
        ")\n",
        "conn.commit()\n",
        "\n",
        "# Quick verification\n",
        "total = cursor.execute('SELECT COUNT(*) FROM employees').fetchone()[0]\n",
        "print(f'Database created successfully with {total} records.')\n",
        "\n",
        "# Preview first 5 rows\n",
        "preview_df = pd.read_sql_query('SELECT * FROM employees LIMIT 5', conn)\n",
        "print('\\nFirst 5 rows:')\n",
        "display(preview_df)"
      ]
    },
